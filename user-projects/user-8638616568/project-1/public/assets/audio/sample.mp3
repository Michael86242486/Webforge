## 2. Backend Setup

### `backend/package.json`
```json
{
  "name": "vibeforge-backend",
  "version": "1.0.0",
  "description": "Backend for VibeForge",
  "main": "server.js",
  "scripts": {
    "start": "node server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  }
}
```

### `backend/server.js`
```js
const express = require('express');
const cors = require('cors');

const app = express();
const PORT = process.env.PORT || 5000;

app.use(cors());
app.use(express.json());

// Inquiry endpoint
app.post('/api/inquiry', (req, res) => {
  const { name, email, message } = req.body;

  // Basic validation
  if (!name || !email || !message) {
    return res.status(400).json({ success: false, message: 'All fields are required.' });
  }

  // Simulate logging or storing inquiry
  console.log(`Inquiry received from ${name} (${email}): ${message}`);

  // Respond with success
  res.json({ success: true, message: 'Inquiry received. We will contact you shortly.' });
});

// GitHub sync endpoint
app.post('/api/github/sync', (req, res) => {
  // Simulate GitHub sync process
  console.log('GitHub sync initiated...');
  // Simulate delay
  setTimeout(() => {
    res.json({ success: true, message: 'GitHub repository synchronized successfully.' });
  }, 2000);
});

app.listen(PORT, () => {
  console.log(`Server running on port ${PORT}`);
});
```

