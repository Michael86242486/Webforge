## 3. Frontend Setup

### `frontend/index.html`
```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>VibeForge Preview</title>
<link rel="stylesheet" href="styles.css" />
</head>
<body>
<header>
  <h1>VibeForge</h1>
  <p>Build your musical future with us</p>
</header>

<main>
  <section class="player-section">
    <h2>Audio Preview</h2>
    <div class="audio-player-container">
      <audio id="audioPreview" controls>
        <source src="assets/audio/sample.mp3" type="audio/mpeg" />
        Your browser does not support the audio element.
      </audio>
    </div>
  </section>

  <section class="inquiry-section">
    <h2>Contact Us / Inquiry</h2>
    <form id="inquiryForm">
      <input type="text" id="name" placeholder="Your Name" required />
      <input type="email" id="email" placeholder="Your Email" required />
      <textarea id="message" rows="4" placeholder="Your Message" required></textarea>
      <button type="submit">Send Inquiry</button>
    </form>
    <div id="inquiryResponse" class="response-message"></div>
  </section>

  <section class="github-sync-section">
    <h2>Sync with GitHub</h2>
    <button id="syncButton">Sync Repository</button>
    <div id="syncResponse" class="response-message"></div>
  </section>
</main>

<footer>
  <p>&copy; 2024 VibeForge. All rights reserved.</p>
</footer>

<script src="script.js"></script>
</body>
</html>
```

